# Variables consumed by docker-compose.yml's `environment:` section.
# These show up in the container's environment when you `docker compose
# run --rm app …`.
#
# CHROME_CDP_URL and BROWSER_MODE are HARDCODED in docker-compose.yml
# (always `remote_debugging` + `http://cdp-proxy:9333`). The proxy
# service forwards to host.docker.internal:9222 with a rewritten Host
# header — see docker/cdp-proxy.conf for why this is necessary.
# Anything below is the user-tunable surface — defaults shown match
# docker-compose.yml's fallbacks.
#
# Copy to `.env` if you want any of these overridden:
#     copy .env.docker.example .env

# Where Flow Labs lives.
FLOW_LABS_URL=https://labs.google/flow

# Persistent-profile-mode setting; remote_debugging mode ignores it.
HEADLESS=false

# How long (seconds) Flow image generation may take.
GENERATION_TIMEOUT_SECONDS=180

# Per-selector timeout (ms) before declaring an element missing.
SELECTOR_TIMEOUT_MS=15000

# Slow each Playwright action by N ms. Useful for debugging.
SLOW_MO_MS=0

# v1 success = reference attached + prompt inserted + arrow clicked.
# No image download yet.
SAVE_OUTPUT_IMAGE=false

# Whether to require a generation-started side-effect within 10s of click.
VERIFY_GENERATION_STARTED=false

# Two-phase tile capture (collect tile_ids, then wait for media_ids).
# 60s gives slow variants room to resolve. Lower to ~15-30 if your
# project is pinned to 1x.
CAPTURE_TIMEOUT_SECONDS=60

# --- AI Product Intake (Phase 3) -------------------------------------------
# Where the UI's AI Product Intake page sends its requests.
# Allowed: openai, anthropic, openrouter, manual.
# `manual` skips API calls — you author prompts in the UI by hand.
#
# IMPORTANT: a ChatGPT / Claude / OpenRouter UI subscription does NOT cover
# the API. Each provider bills its API separately. See docs/AI_PROVIDERS.md.
AI_PROVIDER=manual

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=flow-bof-automation

# --- Automation mode (Phase 4) ---------------------------------------------
# safe / balanced / fast. Individual *_MS env vars override the chosen
# mode if set. Default = safe.
AUTOMATION_MODE=safe
DEBUG_SCREENSHOTS=false

# Phase 4.1 — image-flow speedups
IMAGE_FAST_SUBMIT_MODE=true
IMAGE_SIBLING_WINDOW_MS=2000

# Leave blank to use the AUTOMATION_MODE defaults; set to override.
IMAGE_BETWEEN_PRODUCTS_MS=
IMAGE_UI_SETTLE_MS=
VIDEO_TILE_SETTLE_MS=
VIDEO_AFTER_HOVER_MS=
VIDEO_AFTER_MENU_CLICK_MS=
VIDEO_BETWEEN_PRODUCTS_MS=
VIDEO_RETRY_COUNT=
