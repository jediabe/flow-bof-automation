# Copy this file to .env and adjust as needed.

# --- Browser mode -----------------------------------------------------------
# How Playwright reaches a browser:
#   remote_debugging  → attach to a real Chrome you launched yourself with
#                       --remote-debugging-port. Google sign-in works here.
#   persistent_profile → fallback. Playwright launches its own bundled
#                       Chromium with a persistent user-data-dir. Google
#                       often blocks login in this mode.
BROWSER_MODE=remote_debugging

# CDP endpoint for the real Chrome instance. Default matches the launch
# command in the README.
CHROME_CDP_URL=http://127.0.0.1:9222

# Where Playwright stores the persistent profile (persistent_profile mode only).
# Anything in this directory should be treated like credentials.
BROWSER_USER_DATA_DIR=.browser_profile

# --- Flow Labs --------------------------------------------------------------
# The URL Playwright opens / expects to be on. Override if Flow Labs moves.
FLOW_LABS_URL=https://labs.google/flow

# --- Timing / behaviour -----------------------------------------------------
# Run the browser headless (persistent_profile mode only). Ignored when
# attaching to real Chrome — that window is already visible.
HEADLESS=false

# Per-generation timeout in seconds. Only consulted when SAVE_OUTPUT_IMAGE
# is true; otherwise the flow returns immediately after clicking generate.
GENERATION_TIMEOUT_SECONDS=180

# v1 success = reference attached + prompt inserted + generate clicked.
# We do not yet download the final image (that flow is the next
# milestone, after we wire up image-to-video). Flip to true once the
# download path is reliable.
SAVE_OUTPUT_IMAGE=false

# Whether to require a generation-started side-effect (new result tile,
# loading indicator, generation request) within 10s after clicking the
# arrow. Flow's UI sometimes fires no observable signal even when the
# job is actually running, so v1 leaves this off.
VERIFY_GENERATION_STARTED=false

# How long (seconds) to wait after the generate click for new tiles
# (variants) to appear AND for their media_id URLs to resolve. Two-phase
# capture inside Flow: tile_ids appear fast (~1s), media_ids take
# longer (each variant runs its own backend job, 5-30s). 60s gives
# slow variants enough headroom; set lower if you're producing 1x.
CAPTURE_TIMEOUT_SECONDS=60

# How long to wait (ms) for any selector before declaring it missing.
SELECTOR_TIMEOUT_MS=15000

# Slow each Playwright action by N ms. Useful while debugging. 0 = full speed.
SLOW_MO_MS=0

# --- AI Product Intake (Phase 3) -------------------------------------------
# AI_PROVIDER picks which API to call from the UI's AI Product Intake page.
# Allowed values: openai, anthropic, openrouter, manual.
# `manual` skips API calls — you write prompts yourself in the UI.
#
# IMPORTANT: a ChatGPT / Claude / OpenRouter UI subscription does NOT cover
# API usage. Each provider bills its API separately. See docs/AI_PROVIDERS.md.
AI_PROVIDER=manual

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# Optional attribution headers OpenRouter uses on dashboards.
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=flow-bof-automation

# --- Automation mode -------------------------------------------------------
# Picks the timing profile for both image and video flows.
#   fast     — shortest waits, fewer retries          (default)
#   balanced — slightly longer waits; use only if you see UI races
# (Old "safe" value still parses but is silently treated as "balanced".)
# Per-knob env vars below still override the chosen mode if set.
AUTOMATION_MODE=fast

# Routine debug screenshots in the success path. Always on for errors.
DEBUG_SCREENSHOTS=false

# --- Image-flow speedups (Phase 4.1) ---------------------------------------
# Fast-submit: after clicking generate, wait only for a new tile to appear
# in the gallery — DON'T wait for its media_id URL to resolve. Media IDs
# are filled in by one final sweep after the batch finishes. ~10-20x
# faster per row. Set false to restore the original two-phase wait.
IMAGE_FAST_SUBMIT_MODE=true
# Phase 1 sibling collection window after the first new tile appears.
# Was 5000 ms; 2000 catches the typical 1-2 variants Flow ships and
# skips waiting for siblings that don't exist when variants are pinned to 1x.
IMAGE_SIBLING_WINDOW_MS=2000

# --- Per-step waits (ms). Leave blank to use AUTOMATION_MODE defaults. -----
# Image flow knobs
IMAGE_BETWEEN_PRODUCTS_MS=
IMAGE_UI_SETTLE_MS=
# Video flow knobs
VIDEO_TILE_SETTLE_MS=
VIDEO_AFTER_HOVER_MS=
VIDEO_AFTER_MENU_CLICK_MS=
VIDEO_BETWEEN_PRODUCTS_MS=
VIDEO_RETRY_COUNT=
